{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "BETTER_AUTH_URL",
        "BETTER_AUTH_SECRET",
        "COMMET_WEBHOOK_SECRET",
        "POSTGRES_URL",
        "COMMET_API_KEY",
        "COMMET_ENVIRONMENT",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_BETTER_AUTH_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "clean": {
      "cache": false
    }
  }
}
