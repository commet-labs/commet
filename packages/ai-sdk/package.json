{
  "name": "@commet/ai-sdk",
  "version": "1.0.0",
  "description": "Commet billing middleware for Vercel AI SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "billing",
    "ai",
    "tokens",
    "usage-based-billing",
    "ai-sdk",
    "middleware"
  ],
  "author": "Commet Team",
  "license": "MIT",
  "peerDependencies": {
    "@commet/node": ">=1.10.0",
    "ai": ">=6.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@commet/node": "workspace:*",
    "@types/node": "24.10.1",
    "ai": "^6.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://commet.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/commet-labs/commet.git",
    "directory": "packages/ai-sdk"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
